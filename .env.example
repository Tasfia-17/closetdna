# ──────────────────────────────────────────────
# ClosetDNA — Environment Variables
# Copy this file to .env.local and fill in values
# Never commit .env.local to git
# ──────────────────────────────────────────────

# Aurora PostgreSQL connection string (Neon-compatible)
# Get one free at https://neon.tech → New Project → Connection string
POSTGRES_URL="postgres://user:password@ep-xxxx.us-east-1.aws.neon.tech/closetdna?sslmode=require"

# OpenAI API key — used for Style Genome generation and AI outfit decisions
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# JWT secret — any long random string (32+ chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Your deployed URL (used for absolute redirects in production)
NEXT_PUBLIC_APP_URL="https://closetdna.vercel.app"
